# K.I.N.E.T.I.C. Environment Variables

# Required for Telegram bot
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: restrict access to specific Telegram user IDs (comma-separated)
# TELEGRAM_ALLOWLIST=123456789,987654321

# API keys for providers (set as needed)
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=...
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...
# NVIDIA_API_KEY=nvapi-...
# DEEPSEEK_API_KEY=sk-...
# OLLAMA_API_KEY=ollama  (dummy key for local)

# Required for web search tool
# BRAVE_API_KEY=...

# Agent config
# AGENT_TARGET=main
# API_PORT=18789
# AGENT_MEMORY_MAX=500
