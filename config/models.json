{
  "mode": "multi",
  "embedding": {
    "provider": "ollama-embedding",
    "model": "nomic-embed-text:latest"
  },
  "defaults": {
    "classify": {
      "provider": "groq",
      "model": "openai/gpt-oss-120b",
      "fallbacks": [
        {
          "provider": "lightning",
          "model": "lightning-ai/gpt-oss-120b"
        }
      ]
    },
    "think": {
      "provider": "cloudflare",
      "model": "@cf/google/gemma-4-26b-a4b-it",
      "fallbacks": [
        {
          "provider": "lightning",
          "model": "lightning-ai/gpt-oss-120b"
        }
      ]
    },
    "tool_call": {
      "provider": "lightning",
      "model": "lightning-ai/gpt-oss-120b",
      "fallbacks": [
        {
          "provider": "groq",
          "model": "llama-3.3-70b-versatile"
        }
      ]
    },
    "answer": {
      "provider": "lightning",
      "model": "lightning-ai/gpt-oss-120b",
      "fallbacks": [
        {
          "provider": "groq",
          "model": "llama-3.3-70b-versatile"
        }
      ]
    }
  },
  "providers": {
    "lightning": {
      "baseUrl": "https://lightning.ai/api/v1/",
      "apiKeyEnv": "LIGHTNING_API_KEY"
    },
    "cloudflare": {
      "baseUrl": "https://api.cloudflare.com/client/v4/accounts/ac3e677a5f5a8f21ca4d1526f811657f/ai/v1",
      "apiKeyEnv": "CLOUD_FLARE_API_KEY"
    },
    "opencode": {
      "baseUrl": "https://opencode.ai/zen/go/v1",
      "apiKeyEnv": "OPENCODE_API_KEY"
    },
    "ollama-embedding": {
      "baseUrl": "http://127.0.0.1:11434/v1/",
      "apiKeyEnv": "OLLAMA_API_KEY"
    },
    "ollama": {
      "baseUrl": "http://127.0.0.1:11434/v1/",
      "apiKeyEnv": "OLLAMA_API_KEY"
    },
    "groq": {
      "baseUrl": "https://api.groq.com/openai/v1",
      "apiKeyEnv": "GROQ_API_KEY"
    }
  }
}